---
interface Props {
  color: string;
  title: string;
  icon: string;
  description: string;
}

const { color, title, icon, description } = Astro.props;

const colorMap: Record<string, { bgLight: string; bgDark: string; ring: string; text: string }> = {
  beratung: { bgLight: 'bg-beratung-light', bgDark: 'dark:bg-beratung', ring: 'ring-beratung', text: 'text-beratung' },
  therapie: { bgLight: 'bg-therapie-light', bgDark: 'dark:bg-therapie', ring: 'ring-therapie', text: 'text-therapie' },
  bia: { bgLight: 'bg-bia-light', bgDark: 'dark:bg-bia', ring: 'ring-bia', text: 'text-bia' },
  bgf: { bgLight: 'bg-bgf-light', bgDark: 'dark:bg-bgf', ring: 'ring-bgf', text: 'text-bgf' },
};

const c = colorMap[color] || colorMap.beratung;
---

<section class="bg-white dark:bg-gray-800">
  <div class="container px-5 pt-28 pb-12 lg:pt-32 lg:pb-18 mx-auto">
    <div class="flex flex-col items-center text-center mx-auto">
      <div
        class:list={[
          'shadow-xl inline-flex justify-center items-center lg:p-4 p-4 rounded-full mb-8 ring-4 ring-offset-4 ring-offset-gray-100 dark:ring-offset-gray-900 ring-opacity-50',
          c.bgLight, c.bgDark, c.ring
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 40 40"
          class:list={['dark:text-white lg:w-12 w-8 lg:h-12 h-8', c.text]}
        >
          <path fill="currentColor" d={icon} />
        </svg>
      </div>
      <h1
        class="lg:text-5xl text-3xl mb-4 font-extrabold text-gray-800 dark:text-gray-200"
        style="line-height: 1.25"
      >
        {title}
      </h1>
      <p
        class="text-lg lg:leading-relaxed lg:max-w-4xl text-gray-600 dark:text-gray-300"
      >
        {description}
      </p>
    </div>
  </div>
</section>
