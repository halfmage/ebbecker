---
import Default from '../layouts/Default.astro';
import Services from '../components/Services.astro';

const title = 'Nachricht gesendet';
const description = 'Ihre Nachricht wurde erfolgreich gesendet.';
---

<Default title={title} description={description}>
  <section class="text-gray-700 mb-16">
    <div
      class="container mt-32 px-5 py-16 mx-auto text-center border-b border-gray-200"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-24 h-24 text-primary-600 mx-auto block mb-8"
        fill="none"
        viewBox="0 0 24 24"
      >
        <path
          fill="currentColor"
          d="M23 12l-2.4-2.8.3-3.7-3.6-.8-1.9-3.2L12 3 8.6 1.5 6.7 4.7l-3.6.8.3 3.7L1 12l2.4 2.8-.3 3.7 3.6.8 1.9 3.2L12 21l3.4 1.5 1.9-3.2 3.6-.8-.3-3.7L23 12zm-13 5l-4-4 1.4-1.4 2.6 2.6 6.6-6.6L18 9l-8 8z"
        />
      </svg>
      <h1 class="font-extrabold sm:text-5xl text-2xl text-gray-800 dark:text-gray-50 mb-4">
        {title}
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 block mb-16">{description}</p>
      <a
        href="/"
        class="bg-primary-700 hover:bg-primary-800 text-white px-6 py-3 rounded"
        >Zurück zur Homepage</a
      >
    </div>
  </section>

  <Services />
</Default>
